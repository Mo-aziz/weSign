# Server
NODE_ENV=development
PORT=3000

# MongoDB (required in production)
MONGODB_URI=mongodb://127.0.0.1:27017/wesign

# JWT (required in production — use long random strings)
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# CORS — comma-separated origins
CLIENT_ORIGIN=http://localhost:1420,http://127.0.0.1:1420

# Swagger (on by default in development; set true on Railway to debug)
ENABLE_SWAGGER=true
# SWAGGER_SERVER_URL=https://your-api.up.railway.app
