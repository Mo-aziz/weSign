# Server
NODE_ENV=development
PORT=3000

# MongoDB (required in production)
# Atlas example: mongodb+srv://user:pass@cluster.mongodb.net/wesign?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/wesign

# JWT (required in production — use long random strings)
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# CORS — comma-separated HTTPS origins for web/mobile WebViews
# Production example: https://wesign.app,capacitor://localhost
CLIENT_ORIGIN=
