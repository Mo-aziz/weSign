# Server bind (Railway sets PORT automatically)
HOST=0.0.0.0
PORT=8001

# Optional: comma-separated extra browser origins (merged with localhost defaults).
# Leave empty to allow localhost + *.up.railway.app via CORS regex.
# Example: https://your-custom-domain.com
ALLOWED_ORIGINS=

# Optional: override auto CORS regex (advanced)
# CORS_ORIGIN_REGEX=

# In-memory session TTL for /frame buffers (seconds)
SESSION_TTL_SECONDS=900

# Railway sets RAILWAY_ENVIRONMENT automatically when deployed
