# Server bind (Railway sets PORT automatically)
HOST=0.0.0.0
PORT=8001

# Comma-separated HTTPS origins (required for browser/WebView clients in production)
# Example: https://wesign.app,capacitor://localhost,ionic://localhost
ALLOWED_ORIGINS=

# In-memory session TTL for /frame buffers (seconds)
SESSION_TTL_SECONDS=900

# Railway sets RAILWAY_ENVIRONMENT automatically when deployed
